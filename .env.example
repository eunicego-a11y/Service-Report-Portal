# --- API & Security ---
# Generate: openssl rand -hex 32  (or Python: import secrets; print(secrets.token_hex(32)))
MONDAY_API_KEY=your_monday_api_token_here
SECRET_KEY=your_secret_key_here_minimum_32_chars
ADMIN_PASSWORD=your_admin_password_here

# --- Monday.com OAuth (Get these from https://monday.com/apps) ---
# Go to your Monday.com account > Apps > Develop Apps > Create New App
# Add OAuth Redirect URL: http://localhost:5000/auth/monday/callback (update for production)
MONDAY_OAUTH_CLIENT_ID=your_monday_oauth_client_id
MONDAY_OAUTH_CLIENT_SECRET=your_monday_oauth_client_secret

# --- Google OAuth (Optional) ---
# Get from: https://console.cloud.google.com/
# Redirect URI: http://localhost:5000/auth/google/callback (update for production)
GOOGLE_CLIENT_ID=your_google_client_id_or_leave_blank
GOOGLE_CLIENT_SECRET=your_google_client_secret_or_leave_blank

# --- Board Configuration ---
# Your Monday.com main board ID (visible in URL)
MAIN_BOARD_ID=your_main_board_id
# Linked items board ID (for service requests)
LINKED_BOARD_ID=your_linked_board_id

# --- Column IDs ---
# Get these by inspecting your Monday.com board column details

# Core Fields
COL_NAME=name
COL_SERVICE_REQUEST=board_relation_mks8rnrw

# Contact Information
COL_EMAIL=email_mks72yj4
COL_CUSTOMER_NAME=text_mkw29ykk
COL_CUSTOMER_EMAIL=emailpxq2qbr6

# Service Details
COL_STATUS=color_mks7y5w6
COL_MACHINE_SYSTEM=single_selectn7mh0gm
COL_SERIAL_NUMBER=long_text_mkw3zweq

